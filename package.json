{
  "name": "url_checker",
  "author": "Tyler Kelly",
  "version": "0.2.1",
  "description": "Tool for checking all the links on a page, or a portion of it.",
  "license": "GPL-3.0-only",
  "main": "src/cli.ts",
  "type": "module",
  "bin": "./dist/cli.js",
  "scripts": {
    "url_checker": "tsx ./src/cli.ts",
    "apis": "typedoc",
    "typecheck": "tsc --noEmit",
    "build": "pnpm install && rm -rf dist && tsc",
    "packer": "pnpm run build && pnpm pack",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "bump": "pnpm version --message 'chore: bump version to %s'",
    "ci:check": "pnpm run lint && pnpm run format:check && pnpm run test:coverage && pnpm run typecheck && pnpm run build"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/cli.ts"
    ],
    "out": "docs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.1.1",
    "needle": "^3.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/needle": "^3.3.0",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.5",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "4.1.5",
    "ajv": "^8.20.0",
    "ajv-draft-04": "^1.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19"
  },
  "engines": {
    "node": ">=10.0"
  }
}
